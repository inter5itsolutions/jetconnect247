// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model QuoteRequest {
  id            String   @id @default(cuid())
  flightType    String
  passengers    Int
  departure     String
  destination   String
  date          DateTime
  aircraftId    String?
  name          String
  email         String
  phone         String
  specialRequests String?
  status        String   @default("pending")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Aircraft {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  passengers  Int
  range       String
  speed       String
  hourlyRate  Int
  heroImage   String
  description String
  features    String // JSON stringified array
  status      String   @default("active")
}
